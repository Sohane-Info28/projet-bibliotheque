void rechercherCategorie(LivreArray *livres) {

    char categorie[50];
    int trouve = 0;
    size_t i;

    printf("Categorie recherchee : ");
    fgets(categorie, sizeof(categorie), stdin);

    trim_newline(categorie);

    print_separator();

    for (i = 0; i < livres->size; i++) {

        if (strcmp(livres->data[i].categorie, categorie) == 0) {

            printf("ID : %d\n", livres->data[i].id);
            printf("Titre : %s\n", livres->data[i].titre);
            printf("Auteur : %s\n", livres->data[i].auteur);
            printf("Disponible : %s\n",
                   livres->data[i].estEmprunte ? "Non" : "Oui");

            print_separator();

            trouve = 1;
        }
    }

    if (!trouve) {
        printf("Aucun livre trouve.\n");
    }
}

