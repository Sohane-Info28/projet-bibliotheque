/* PHASE 2 complétée : charger les emprunts depuis emprunts.txt */
Emprunt* chargerEmprunts(int *nbEmprunts) {
    FILE *fichier;
    Emprunt *tab;
    int i;

    fichier = fopen("emprunts.txt", "r");
    if (fichier == NULL) {
        printf("Fichier emprunts.txt non trouve (ou vide). Initialisation a 0.\n");
        *nbEmprunts = 0;
        return NULL;
    }

    // On lit le nombre d'emprunts sur la première ligne
    if (fscanf(fichier, "%d", nbEmprunts) != 1) {
        *nbEmprunts = 0;
        fclose(fichier);
        return NULL;
    }

    // Allocation dynamique (Tâche 5)
    tab = malloc((*nbEmprunts) * sizeof(Emprunt));
    if (tab == NULL) {
        printf("Erreur allocation memoire pour les emprunts\n");
        fclose(fichier);
        *nbEmprunts = 0;
        return NULL;
    }

    // Lecture de chaque ligne // On lit l'ID du livre, le login et le timestamp de la date de rendu
for (i = 0; i < *nbEmprunts; i++) {
// On lit l'ID du livre, le login et le timestamp de la date de rendu
    if (fscanf(fichier, "%d %s %ld",
               &tab[i].idLivre,
               tab[i].loginUser,
               &tab[i].dateRendu) != 3) {
        printf("Erreur lecture emprunt\n");
    }
}
    fclose(fichier);
    return tab;
}










